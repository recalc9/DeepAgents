# DeepSeek 平台密钥
DEEPSEEK_API_KEY=
# DeepSeek 兼容 OpenAI 接口地址（Node/TS 用 baseURL）
DEEPSEEK_BASE_URL=
# 推荐新版模型（2026 官方主推）
DEEPSEEK_MODEL=
# 可选：deepseek-v4-pro / deepseek-reasoner(R1)

# PostgreSQL 连接（独立变量）
PGHOST=localhost
PGPORT=5432
PGDATABASE=deepagent
PGUSER=postgres
PGPASSWORD=
# 或使用单连接字符串（优先于上述独立变量）
# DATABASE_URL=postgresql://user:pass@localhost:5432/deepagent